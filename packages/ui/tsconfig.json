{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@noter/ui/components/*": ["./src/components/*"],
      "@noter/ui/hooks/*": ["./src/hooks/*"],
      "@noter/ui/lib/*": ["./src/lib/*"]
    }
  },
  "include": ["src"]
}
